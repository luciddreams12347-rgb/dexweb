# Flask session signing key. Use a long random value in production.
APP_SECRET=

# Admin panel password used at /admin_login.
ADMIN_PASSWORD=

# Optional MySQL connection string.
# Example format: mysql+pymysql://user:password@host:3306/database_name
DATABASE_URL=

# Alternative MySQL settings if your host does not provide DATABASE_URL.
DEX_DB_ENABLED=false
DEX_DB_HOST=
DEX_DB_PORT=3306
DEX_DB_USER=
DEX_DB_PASSWORD=
DEX_DB_NAME=

# Optional path to a readable server log file shown in the admin panel.
DEX_SITE_LOG_PATH=

# Maximum in-memory chat messages retained per room.
DEX_MAX_MESSAGES_PER_ROOM=200

# Local development only. Set true to enable Flask debug mode.
DEX_DEBUG=false

# Hosting providers often set PORT automatically. Local default is 5000.
PORT=5000

# Optional DEX system prompt storage path. If empty, DexWeb stores edited prompts
# in the Flask instance folder and falls back to the packaged default prompt.
DEX_SYSTEM_PROMPT_PATH=

# Future AI provider selection. The current built-in provider is local-placeholder.
DEX_PROVIDER=local-placeholder

# Future AI model name. Leave empty while using local-placeholder.
DEX_MODEL=

# Optional upload storage path for DEX Library V1.
LIBRARY_UPLOADS_DIR=

# Maximum accepted upload size in bytes for DEX Library.
LIBRARY_MAX_UPLOAD_BYTES=10485760
